# ⚠️ WARNING: Never commit real API keys to version control.
# If your keys have been exposed in any way (logs, screenshots, git history),
# rotate them immediately on the provider's dashboard.
# The .env file is git-ignored; keep it that way.

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MiniMax API (Token Plan)
MINIMAX_API_KEY=your_minimax_api_key_here
# MiniMax Group ID (Token Plan users need this)
MINIMAX_GROUP_ID=your_minimax_group_id_here
